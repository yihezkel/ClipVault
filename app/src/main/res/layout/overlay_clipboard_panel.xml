<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:clickable="true"
    android:focusable="true">

    <!-- Transparent touch-catcher on the left side (dismiss on tap) -->
    <View
        android:id="@+id/dismiss_area"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3" />

    <!-- The actual panel on the right -->
    <LinearLayout
        android:id="@+id/panel_content"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="7"
        android:orientation="vertical"
        android:background="#FF1E1E2E"
        android:padding="12dp"
        android:elevation="8dp">

        <!-- Header row: title + sort toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ClipVault"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sort_toggle_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 first"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/add_clip_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Search bar -->
        <EditText
            android:id="@+id/search_edit_text"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Search clips…"
            android:textColorHint="#88FFFFFF"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/search_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textSize="14sp" />

        <!-- Multi-select action bar (hidden by default) -->
        <LinearLayout
            android:id="@+id/multi_select_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/selection_count_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/action_pin_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 Pin"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/action_unpin_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unpin"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/action_delete_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ Delete"
                android:textColor="#FFFF6B6B"
                android:textSize="13sp"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/action_cancel_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="#88FFFFFF"
                android:textSize="13sp"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Clip list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/clips_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

</LinearLayout>
